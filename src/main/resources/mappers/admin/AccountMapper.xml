<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.1//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wangagain.wx.mapper.admin.AccountMapper">

    <!--
    select : 查询
    update: 修改
    delete: 删除
    insert: 添加

    resultType: 根据表中字段和类中属性一致时
    resultMap: 根据表中字段和类中属性不一致时
    -->

    <resultMap id="accountMap" type="com.wangagain.wx.entity.admin.Account">
        <id property="uId" column="uId"/>
        <result property="uName" column="uName"/>
        <result property="uPwd" column="uPwd"/>
    </resultMap>

    <select id="login" resultMap="accountMap">
        SELECT uId,uName,uPwd FROM account WHERE uName = #{uName} and uPwd=#{uPwd}
    </select>
    
    <insert id="register">
        insert into account(uName,uPwd) values(#{uName},#{uPwd})
    </insert>
    
    <select id="findUserExist" resultMap="accountMap">
        SELECT uId,uName,uPwd FROM account WHERE uName = #{uName}
    </select>
    
    <select id="allUsers" resultMap="accountMap">
        SELECT uId,uName,uPwd FROM account
    </select>

</mapper>