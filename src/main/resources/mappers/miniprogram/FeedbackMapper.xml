<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.1//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wangagain.wx.mapper.miniprogram.FeedbackMapper">

    <resultMap id="feedbackMap" type="com.wangagain.wx.entity.miniprogram.Feedback">
        <id property="id" column="id"/>
        <result property="reportId" column="report_id"/>
        <result property="content" column="content"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 添加反馈 -->
    <insert id="addFeedback" parameterType="com.wangagain.wx.entity.miniprogram.Feedback">
        insert into feedback (report_id, content, create_time)
        values (#{reportId}, #{content}, #{createTime})
    </insert>

    <!-- 根据ID查询反馈 -->
    <select id="getFeedbackById" parameterType="int" resultMap="feedbackMap">
        select id, report_id, content, create_time from feedback where id = #{id}
    </select>

    <!-- 查询所有反馈 -->
    <select id="getAllFeedbacks" resultMap="feedbackMap">
        select id, report_id, content, create_time from feedback order by create_time desc
    </select>

    <!-- 更新反馈状态（暂时保留接口） -->
    <update id="updateFeedbackStatus" parameterType="com.wangagain.wx.entity.miniprogram.Feedback">
        update feedback
        set content = #{content}
        where id = #{id}
    </update>

    <!-- 根据用户ID查询反馈（暂时保留接口，使用report_id代替） -->
    <select id="getFeedbacksByUserId" parameterType="int" resultMap="feedbackMap">
        select id, report_id, content, create_time from feedback where report_id = #{userId} order by create_time desc
    </select>

</mapper>
